# Sam v2 — Environment Variables
# Copy this file to .env.local and fill in your values.

# ── Required ─────────────────────────────────────────────────────────────────

# Anthropic API key — powers the Claude chat model
ANTHROPIC_API_KEY=

# ── RAG Pipeline (enables semantic business search) ──────────────────────────
# Without these, Sam falls back to loading all businesses into the prompt.
# With them, Sam retrieves only the most relevant businesses per query.

# OpenAI API key — used for text-embedding-3-small to embed queries + businesses
OPENAI_API_KEY=

# Pinecone API key — vector database for semantic business search
PINECONE_API_KEY=

# ── Optional / Vercel-managed ────────────────────────────────────────────────
# These are auto-populated by Vercel on deploy. Only needed for local dev
# if you're testing specific integrations.

# Vercel Blob (for future media uploads)
# BLOB_READ_WRITE_TOKEN=

# Postgres (reserved for Phase 3 conversation analytics)
# DATABASE_URL=

# Redis / KV (reserved for rate limiting)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
